# Orchestration state -- auto-generated by orchestrate-loop.sh
# Copy this to orchestration-state.env and values will be populated at runtime.
# Do not edit manually unless resuming from a known state.

# Which agent last implemented a task (codex or claude)
LAST_IMPLEMENTER=

# Counters for the current orchestration run
TASKS_PROCESSED=
TASKS_PASSED=
TASKS_FAILED=
ESCALATION_COUNT=

# Path to the tasks file being processed (relative to project root)
TASKS_FILE=

# Git branch being worked on
BRANCH=

# Specs directory path (relative to project root)
SPECS_PATH=

# Plan file path (relative to project root)
PLAN_FILE=

# Git remote name (default: github)
GIT_REMOTE=

# Test command to run for verification (e.g., "pytest tests/ -x -q")
TEST_CMD=

# Lint command to run for verification (e.g., "ruff check .")
LINT_CMD=

# Comma-separated files agents should read first
BOOTSTRAP_READS=

# ISO-8601 timestamp of last state save
TIMESTAMP=
